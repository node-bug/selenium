{
  "name": "@nodebug/selenium",
  "version": "5.1.9",
  "lockfileVersion": 1,
  "requires": true,
  "author": {
    "name": "Node Bug",
    "email": "nodebug@outlook.com"
  },
  "bugs": {
    "url": "https://github.com/node-bug/selenium/issues"
  },
  "dependencies": {
    "@nodebug/config": "2.1.3",
    "@nodebug/logger": "1.1.4",
    "chai": "6.2.2",
    "selenium-webdriver": "4.43.0"
  },
  "description": "implementation of seleniumjs to use with test automation",
  "homepage": "https://github.com/node-bug/selenium#readme",
  "keywords": [
    "selenium",
    "npm",
    "chrome",
    "firefox",
    "ie",
    "edge",
    "test",
    "automation",
    "page",
    "object",
    "webdriver",
    "chai"
  ],
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/node-bug/selenium.git"
  },
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "lint": "eslint .",
    "prepare": "husky && echo 'npx lint-staged' > .husky/pre-commit && chmod +x .husky/pre-commit"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/selenium-webdriver": "^4.35.5",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "typescript-eslint": "^8.58.1",
    "sinon": "^21.1.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "*.{json,yaml,yml,md,sh,groovy}": [
      "prettier --write"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "contributors": [
    {
      "name": "Node Bug",
      "email": "nodebug@outlook.com"
    }
  ],
  "files": [
    ".config",
    "app",
    "docs",
    "index.js",
    "index.d.ts",
    "LICENSE",
    "README.md"
  ]
}
